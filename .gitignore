# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.vscode/

# Runtime outputs
/report.json
/reports/
/logs/
/bin/

# External repositories. Keep only the curated list of subjects.
/repos/*
!/repos/repos.txt
/data/repos/

# Raw and historical experimental data
/data/probe/
/data/characterization/old/
/data/baseline/*.json
!/data/baseline/*passonly.json

# Benchmark results are generated; configs are versioned.
/benchmarks/results/

# Internal documentation, not part of the public project artifact.
/docs